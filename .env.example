# Google service account JSON
# Set this to the full JSON string in Pages runtime.
GOOGLE_APPLICATION_CREDENTIALS={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"..."}

# Tournament sheet ID (from the spreadsheet URL: /d/<ID>/edit)
GOOGLE_SHEETS_TOURNAMENT_ID=1oZYbk_rBgs2M6AOAq5Vc3TTHBlv5qg5a19N-AAUFU2Q

# osu! OAuth2 (https://osu.ppy.sh/home/account/edit → OAuth)
OSU_CLIENT_ID=your_client_id
OSU_CLIENT_SECRET=your_client_secret
OSU_REDIRECT_URI=https://your-pages-domain.pages.dev/auth/callback

# Session signing secret (generate: openssl rand -hex 32)
SESSION_SECRET=replace_with_64_char_hex_string

# osu! IRC bot account (from osu! account settings → IRC)
IRC_BOT_USERNAME=YourOsuUsername
IRC_BOT_PASSWORD=your_irc_server_password
